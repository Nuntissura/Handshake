      "sh",
      "-c",
      "test \"$HANDSHAKE_MT057\" = \"present\" && exit 0 || exit 7"
    ],
    "env": {
      "HANDSHAKE_MT057": "present"
    },
    "cwd": null,
    "binds": [],
    "net_policy": "deny_all",
    "resource_limits": {
      "memory_bytes": null,
      "cpu_cores": null,
      "timeout_ms": null
    },
    "required_capabilities": [],
    "metadata": {}
  },
  "expected": {
    "exit_code_class": "zero",
    "stop_reason_contains": "status:exited"
  }
}
