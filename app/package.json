{
  "name": "app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:harness": "vite build --config vite.harness.config.ts",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:dependency-policy": "playwright test --config playwright.dependency.config.ts",
    "check:portable-artifacts": "vitest run src/lib/dependency_policy/portable_build_artifacts.test.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "depcruise": "dependency-cruiser --config .dependency-cruiser.cjs src",
    "screenshot:capture": "node scripts/handshake-screenshot-capture.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/core": "^3.13.0",
    "@tiptap/extension-collaboration": "^3.13.0",
    "@tiptap/extension-list": "^3.13.0",
    "@tiptap/extension-mention": "^3.13.0",
    "@tiptap/extension-table": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@tiptap/suggestion": "^3.13.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitejs/plugin-react": "^4.6.0",
    "ajv": "^8.20.0",
    "dependency-cruiser": "^17.3.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.0.15",
    "yaml": "^2.9.0"
  }
}
