+#[derive(Debug, Clone, Copy, Serialize, Deserialize, PartialEq, Eq)]
+#[serde(rename_all = "snake_case")]
+pub enum SoftwareDeliveryWorkflowBindingState {
+    Created,
+    Queued,
+    Claimed,
+    NodeActive,
+    ApprovalWait,
+    ValidationWait,
+    CloseoutPending,
