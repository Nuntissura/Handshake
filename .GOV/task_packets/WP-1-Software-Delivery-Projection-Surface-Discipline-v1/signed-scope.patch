index bf0057ef..9685591c 100644
--- a/src/backend/handshake_core/src/storage/locus_sqlite.rs
+++ b/src/backend/handshake_core/src/storage/locus_sqlite.rs
@@ -19,0 +20,3 @@ use crate::workflows::locus::types::{
+use crate::workflows::locus::types::{
+    governed_action_ids_for_family, resolve_queue_reason_with_mailbox_context,
+};
