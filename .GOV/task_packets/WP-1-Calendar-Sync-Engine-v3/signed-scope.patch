+        ),
+        EngineStatus::Failed => (
+            JobState::Failed,
+            "calendar_sync_failed".to_string(),
+            result.errors.first().map(|err| err.message.clone()),
+        ),
+    };
+
+    Ok(RunJobOutcome {
+        state,
+        status_reason,
+        output: Some(output),
+        error_message,
+    })
+}
