+        r#"
+        CREATE TABLE IF NOT EXISTS work_packets (
+            wp_id TEXT PRIMARY KEY,
+            version BIGINT NOT NULL,
+            title TEXT NOT NULL,
+            description TEXT,
+            status TEXT NOT NULL,
+            priority BIGINT NOT NULL,
+            phase TEXT,
