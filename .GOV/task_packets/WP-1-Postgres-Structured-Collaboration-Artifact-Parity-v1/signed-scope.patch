+async fn delete_wp(pool: &PgPool, params: LocusDeleteWpParams) -> StorageResult<Value> {
+    ensure_wp_exists(pool, &params.wp_id).await?;
+    let now = now_rfc3339();
+
+    let row = sqlx::query_scalar::<_, String>("SELECT metadata FROM work_packets WHERE wp_id = $1")
+        .bind(&params.wp_id)
+        .fetch_one(pool)
