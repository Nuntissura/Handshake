+async fn ensure_wp_exists(pool: &PgPool, wp_id: &str) -> StorageResult<()> {
+    let exists =
+        sqlx::query_scalar::<_, bool>("SELECT EXISTS(SELECT 1 FROM work_packets WHERE wp_id = $1)")
+        .bind(wp_id)
+        .fetch_one(pool)
+        .await?;
+
+    if !exists {
+        return Err(StorageError::NotFound("work_packet"));
+    }
