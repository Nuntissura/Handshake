{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hsk.refinement_contract@1",
  "title": "Handshake Refinement Contract",
  "type": "object",
  "required": ["schema_id", "schema_version", "contract_authority", "wp_id", "authority_files", "markdown_projection", "activation_manager", "refinement", "red_team"],
  "properties": {
    "schema_id": { "const": "hsk.refinement_contract@1" },
    "schema_version": { "type": "string", "minLength": 1 },
    "contract_authority": { "const": "PRIMARY_MACHINE_READABLE" },
    "wp_id": { "type": "string", "pattern": "^WP-[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "created_at_utc": { "type": "string" },
    "updated_at_utc": { "type": ["string", "null"] },
    "authority_files": { "type": "object", "required": ["refinement_contract", "refinement_projection", "packet_contract"], "additionalProperties": { "type": "string" } },
    "markdown_projection": { "$ref": "#/$defs/markdown_projection" },
    "activation_manager": { "type": "object", "required": ["required", "status"], "properties": { "required": { "type": "boolean" }, "status": { "type": "string" } }, "additionalProperties": true },
    "refinement": { "type": "object" },
    "red_team": { "$ref": "#/$defs/red_team" }
  },
  "additionalProperties": true,
  "$defs": {
    "markdown_projection": { "type": "object", "required": ["path", "status"], "properties": { "path": { "type": "string" }, "status": { "enum": ["GENERATED_PENDING", "GENERATED_IN_SYNC", "LEGACY_AUTHORITY", "BLOCKED"] } }, "additionalProperties": true },
    "red_team": { "type": "object", "required": ["required", "profile"], "properties": { "required": { "const": true }, "profile": { "const": "DETERMINISTIC_CONTRACT_MIGRATION_V1" } }, "additionalProperties": true }
  }
}

