{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handshake.local/schemas/SESSION_CONTROL_REQUEST.schema.json",
  "title": "Session Control Request",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "command_id",
    "created_at",
    "command_kind",
    "created_by_role",
    "session_key",
    "wp_id",
    "role",
    "output_jsonl_file"
  ],
  "properties": {
    "schema_id": {
      "const": "hsk.session_control_request@1"
    },
    "schema_version": {
      "const": "session_control_request_v1"
    },
    "command_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "command_kind": {
      "enum": [
        "START_SESSION",
        "SEND_PROMPT",
        "CANCEL_SESSION",
        "CLOSE_SESSION"
      ]
    },
    "created_by_role": {
      "const": "ORCHESTRATOR"
    },
    "session_key": {
      "type": "string"
    },
    "wp_id": {
      "type": "string",
      "pattern": "^WP-"
    },
    "role": {
      "enum": [
        "CODER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR"
      ]
    },
    "session_thread_id": {
      "type": "string"
    },
    "local_branch": {
      "type": "string"
    },
    "local_worktree_dir": {
      "type": "string"
    },
    "abs_worktree_dir": {
      "type": "string"
    },
    "selected_model": {
      "type": "string"
    },
    "selected_profile_id": {
      "type": "string"
    },
    "reasoning_config_key": {
      "type": "string"
    },
    "reasoning_config_value": {
      "type": "string"
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "target_command_id": {
      "type": "string",
      "minLength": 1
    },
    "cancel_target_command_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "output_jsonl_file": {
      "type": "string"
    },
    "busy_ingress_mode": {
      "enum": [
        "REJECT",
        "ENQUEUE_ON_BUSY"
      ]
    },
    "environment_overrides": {
      "type": "object"
    },
    "governed_action": {
      "type": "object"
    },
    "workflow_contract": {
      "type": "object",
      "required": [
        "schema_id",
        "schema_version",
        "contract_id",
        "contract_version",
        "lane",
        "role",
        "consumers"
      ],
      "properties": {
        "schema_id": {
          "const": "hsk.workflow_contract_envelope@1"
        },
        "schema_version": {
          "const": "workflow_contract_envelope_v1"
        },
        "contract_id": {
          "type": "string"
        },
        "contract_version": {
          "type": "string"
        },
        "lane": {
          "enum": [
            "ORCHESTRATOR_MANAGED",
            "MANUAL_RELAY"
          ]
        },
        "role": {
          "type": "string"
        },
        "consumers": {
          "type": "array",
          "contains": {
            "const": "ACP_SESSION_CONTROL"
          }
        }
      }
    },
    "role_startup_capsule": {
      "type": "object",
      "required": [
        "schema_id",
        "schema_version",
        "generated_at",
        "role",
        "wp_id",
        "authority_files",
        "work_packet_contract",
        "refinement_contract",
        "microtask_contract",
        "runtime_receipt_state",
        "first_commands"
      ],
      "properties": {
        "schema_id": {
          "const": "hsk.role_startup_capsule@1"
        },
        "schema_version": {
          "const": "role_startup_capsule_v1"
        },
        "generated_at": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "wp_id": {
          "type": "string",
          "pattern": "^WP-"
        },
        "authority_files": {
          "type": "array",
          "minItems": 1
        },
        "work_packet_contract": {
          "type": "object"
        },
        "refinement_contract": {
          "type": "object"
        },
        "microtask_contract": {
          "type": "object"
        },
        "runtime_receipt_state": {
          "type": "object"
        },
        "first_commands": {
          "type": "array"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command_kind": {
            "enum": [
              "START_SESSION",
              "SEND_PROMPT"
            ]
          }
        }
      },
      "then": {
        "required": [
          "selected_model",
          "prompt"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command_kind": {
            "const": "CANCEL_SESSION"
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "target_command_id"
            ]
          },
          {
            "required": [
              "cancel_target_command_id"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command_kind": {
            "const": "CLOSE_SESSION"
          }
        }
      },
      "then": {}
    }
  ],
  "additionalProperties": false
}
