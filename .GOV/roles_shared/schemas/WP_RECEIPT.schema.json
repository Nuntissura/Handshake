{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handshake.local/gov/schemas/WP_RECEIPT.schema.json",
  "title": "WP Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp_utc",
    "wp_id",
    "actor_role",
    "actor_session",
    "actor_authority_kind",
    "validator_role_kind",
    "receipt_kind",
    "summary",
    "branch",
    "worktree_dir",
    "state_before",
    "state_after",
    "refs"
  ],
  "properties": {
    "schema_version": {
      "const": "wp_receipt@1"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "wp_id": {
      "type": "string",
      "pattern": "^WP-"
    },
    "actor_role": {
      "enum": [
        "SYSTEM",
        "OPERATOR",
        "ORCHESTRATOR",
        "CODER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "VALIDATOR"
      ]
    },
    "actor_session": {
      "type": "string",
      "minLength": 1
    },
    "actor_authority_kind": {
      "enum": [
        "SYSTEM",
        "OPERATOR",
        "WORKFLOW_AUTHORITY",
        "PRIMARY_CODER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "SECONDARY_VALIDATOR"
      ]
    },
    "validator_role_kind": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "SECONDARY_VALIDATOR",
        null
      ]
    },
    "receipt_kind": {
      "enum": [
        "ASSIGNMENT",
        "STATUS",
        "HEARTBEAT",
        "HANDOFF",
        "THREAD_MESSAGE",
        "VALIDATOR_KICKOFF",
        "CODER_INTENT",
        "CODER_HANDOFF",
        "VALIDATOR_REVIEW",
        "VALIDATOR_QUERY",
        "VALIDATOR_RESPONSE",
        "REVIEW_REQUEST",
        "REVIEW_RESPONSE",
        "SPEC_GAP",
        "SPEC_CONFIRMATION",
        "VALIDATION_START",
        "VALIDATION_STATUS_SYNC",
        "STEERING",
        "REPAIR"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "worktree_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_before": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_after": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "OPERATOR",
        "ORCHESTRATOR",
        "CODER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "VALIDATOR",
        null
      ]
    },
    "target_session": {
      "type": [
        "string",
        "null"
      ]
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requires_ack": {
      "type": "boolean"
    },
    "ack_for": {
      "type": [
        "string",
        "null"
      ]
    },
    "spec_anchor": {
      "type": [
        "string",
        "null"
      ]
    },
    "packet_row_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
