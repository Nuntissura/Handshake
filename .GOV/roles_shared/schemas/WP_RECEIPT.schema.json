{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handshake.local/gov/schemas/WP_RECEIPT.schema.json",
  "title": "WP Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "timestamp_utc",
    "wp_id",
    "actor_role",
    "actor_session",
    "actor_authority_kind",
    "validator_role_kind",
    "receipt_kind",
    "summary",
    "branch",
    "worktree_dir",
    "state_before",
    "state_after",
    "refs"
  ],
  "properties": {
    "schema_version": {
      "const": "wp_receipt@1"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "wp_id": {
      "type": "string",
      "pattern": "^WP-"
    },
    "actor_role": {
      "enum": [
        "SYSTEM",
        "OPERATOR",
        "ORCHESTRATOR",
        "CODER",
        "MEMORY_MANAGER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "VALIDATOR"
      ]
    },
    "actor_session": {
      "type": "string",
      "minLength": 1
    },
    "actor_authority_kind": {
      "enum": [
        "SYSTEM",
        "OPERATOR",
        "WORKFLOW_AUTHORITY",
        "PRIMARY_CODER",
        "MEMORY_MANAGER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "SECONDARY_VALIDATOR"
      ]
    },
    "validator_role_kind": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "SECONDARY_VALIDATOR",
        null
      ]
    },
    "receipt_kind": {
      "enum": [
        "ASSIGNMENT",
        "STATUS",
        "HEARTBEAT",
        "HANDOFF",
        "THREAD_MESSAGE",
        "VALIDATOR_KICKOFF",
        "CODER_INTENT",
        "CODER_HANDOFF",
        "VALIDATOR_REVIEW",
        "MT_VERDICT_MECHANICAL",
        "VALIDATOR_QUERY",
        "VALIDATOR_RESPONSE",
        "REVIEW_REQUEST",
        "REVIEW_RESPONSE",
        "SPEC_GAP",
        "SPEC_CONFIRMATION",
        "VALIDATION_START",
        "VALIDATION_STATUS_SYNC",
        "STEERING",
        "REPAIR",
        "WORKFLOW_INVALIDITY",
        "MEMORY_PROPOSAL",
        "MEMORY_FLAG",
        "MEMORY_RGF_CANDIDATE"
      ]
    },
    "verb": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "MT_HANDOFF",
        "MT_VERDICT",
        "MT_REMEDIATION_REQUIRED",
        "WP_HANDOFF",
        "INTEGRATION_VERDICT",
        "CONCERN",
        "PHASE_TRANSITION",
        "RELAUNCH_REQUEST",
        null
      ]
    },
    "verb_body": {
      "type": [
        "object",
        "null"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "branch": {
      "type": [
        "string",
        "null"
      ]
    },
    "worktree_dir": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_before": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_after": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_role": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "OPERATOR",
        "ORCHESTRATOR",
        "CODER",
        "MEMORY_MANAGER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR",
        "VALIDATOR",
        null
      ]
    },
    "target_session": {
      "type": [
        "string",
        "null"
      ]
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "requires_ack": {
      "type": "boolean"
    },
    "ack_for": {
      "type": [
        "string",
        "null"
      ]
    },
    "spec_anchor": {
      "type": [
        "string",
        "null"
      ]
    },
    "packet_row_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "microtask_contract": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "scope_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "file_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "proof_commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_focus": {
          "type": [
            "string",
            "null"
          ]
        },
        "heuristic_risk": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "YES",
            "NO",
            null
          ]
        },
        "heuristic_risk_class": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "NONE",
            "FUZZY_DISCRIMINATOR",
            "THRESHOLD_TUNING",
            "ADVERSARIAL_INPUT",
            "NATURAL_LANGUAGE_CLASSIFICATION",
            "PROBABILISTIC_SCORING",
            "SECRET_OR_IDENTIFIER_BOUNDARY",
            "OTHER",
            null
          ]
        },
        "required_evidence": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CORPUS_CASES",
              "PROPERTY_TESTS",
              "NEGATIVE_COUNTEREXAMPLES",
              "BOUNDARY_MATRIX",
              "THRESHOLD_RATIONALE",
              "FALSE_POSITIVE_FALSE_NEGATIVE_PROBES",
              "ADVERSARIAL_PROBES"
            ]
          }
        },
        "strategy_escalation": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "NONE",
            "CORPUS_EXPANSION",
            "PROPERTY_BASED_REFRAME",
            "DISCRIMINATOR_REDESIGN",
            "BOUNDARY_CONTRACT_REWRITE",
            "ALTERNATE_MODEL_REVIEW",
            "HUMAN_STOP",
            null
          ]
        },
        "repair_cycle_strategy_threshold": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "review_mode": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "BLOCKING",
            "OVERLAP",
            null
          ]
        },
        "phase_gate": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "BOOTSTRAP",
            "SKELETON",
            "MICROTASK",
            "FINAL_REVIEW",
            null
          ]
        },
        "review_outcome": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "UNKNOWN",
            "REPAIR_REQUIRED",
            "APPROVED_FOR_FINAL_REVIEW",
            null
          ]
        },
        "expected_receipt_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ASSIGNMENT",
            "STATUS",
            "HEARTBEAT",
            "HANDOFF",
            "THREAD_MESSAGE",
            "VALIDATOR_KICKOFF",
            "CODER_INTENT",
            "CODER_HANDOFF",
            "VALIDATOR_REVIEW",
            "MT_VERDICT_MECHANICAL",
            "VALIDATOR_QUERY",
            "VALIDATOR_RESPONSE",
            "REVIEW_REQUEST",
            "REVIEW_RESPONSE",
            "SPEC_GAP",
            "SPEC_CONFIRMATION",
            "VALIDATION_START",
            "VALIDATION_STATUS_SYNC",
            "STEERING",
            "REPAIR",
            "WORKFLOW_INVALIDITY",
            null
          ]
        }
      }
    },
    "mechanical_result": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "mt_id",
        "verdict",
        "concerns",
        "boundary_check_result",
        "scope_check_result",
        "file_list_match_result",
        "build_pass_evidence",
        "helper_invocation_id"
      ],
      "properties": {
        "mt_id": {
          "type": "string",
          "pattern": "^MT-[0-9]{3}$"
        },
        "verdict": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "concerns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "severity",
              "evidence_path"
            ],
            "properties": {
              "key": {
                "type": "string",
                "minLength": 1
              },
              "severity": {
                "type": "string",
                "enum": [
                  "LOW",
                  "MEDIUM",
                  "HIGH",
                  "CRITICAL"
                ]
              },
              "evidence_path": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "boundary_check_result": {
          "type": "object"
        },
        "scope_check_result": {
          "type": "object"
        },
        "file_list_match_result": {
          "type": "object"
        },
        "build_pass_evidence": {
          "type": "object"
        },
        "helper_invocation_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflow_invalidity_code": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Z0-9_]+$"
    },
    "metadata": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true,
      "properties": {
        "absorbers_applied": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
