{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handshake.local/schemas/SESSION_CONTROL_REQUEST.schema.json",
  "title": "Session Control Request",
  "type": "object",
  "required": [
    "schema_id",
    "schema_version",
    "command_id",
    "created_at",
    "command_kind",
    "created_by_role",
    "session_key",
    "wp_id",
    "role",
    "output_jsonl_file"
  ],
  "properties": {
    "schema_id": {
      "const": "hsk.session_control_request@1"
    },
    "schema_version": {
      "const": "session_control_request_v1"
    },
    "command_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "command_kind": {
      "enum": [
        "START_SESSION",
        "SEND_PROMPT",
        "CANCEL_SESSION",
        "CLOSE_SESSION"
      ]
    },
    "created_by_role": {
      "const": "ORCHESTRATOR"
    },
    "session_key": {
      "type": "string"
    },
    "wp_id": {
      "type": "string",
      "pattern": "^WP-"
    },
    "role": {
      "enum": [
        "CODER",
        "WP_VALIDATOR",
        "INTEGRATION_VALIDATOR"
      ]
    },
    "session_thread_id": {
      "type": "string"
    },
    "local_branch": {
      "type": "string"
    },
    "local_worktree_dir": {
      "type": "string"
    },
    "abs_worktree_dir": {
      "type": "string"
    },
    "selected_model": {
      "type": "string"
    },
    "reasoning_config_key": {
      "type": "string"
    },
    "reasoning_config_value": {
      "type": "string"
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "target_command_id": {
      "type": "string",
      "minLength": 1
    },
    "cancel_target_command_id": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "output_jsonl_file": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command_kind": {
            "enum": [
              "START_SESSION",
              "SEND_PROMPT"
            ]
          }
        }
      },
      "then": {
        "required": [
          "selected_model",
          "prompt"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command_kind": {
            "const": "CANCEL_SESSION"
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "required": [
              "target_command_id"
            ]
          },
          {
            "required": [
              "cancel_target_command_id"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command_kind": {
            "const": "CLOSE_SESSION"
          }
        }
      },
      "then": {}
    }
  ],
  "additionalProperties": false
}
